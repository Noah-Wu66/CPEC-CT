# ============================================================
# 智创 AI 工作台 - 环境变量示例
# 复制为 .env.local 后按需填写。带 (必填) 的为最小可运行所需。
# ============================================================

# --- 基础 (必填) ---
# MongoDB 连接串：存放用户、会话、对话、音频与采集记录
MONGO_URI=mongodb://localhost:27017/ai-studio
# 会话/安全密钥：生产环境务必设置为高强度随机串
AUTH_SECRET=please-change-this-to-a-long-random-string

# --- MiniMax 官方国内版平台（对话 MiniMax-M3，图像 image-01，音频 Speech 系列）---
# MiniMax API Key：驱动 AI 对话、图像生成、字幕翻译、数据采集智能体、语音合成与声音克隆
# 在 https://platform.minimaxi.com 申请
MINIMAX_API_KEY=

# --- 火山引擎语音识别（ASR）---
# 仅录音转写 / 字幕识别用到
VOLCENGINE_SPEECH_API_KEY=

# --- 存储与采集 ---
# Vercel Blob 存储令牌（音频与对话附件）
BLOB_READ_WRITE_TOKEN=
# XCrawl 采集服务密钥
XCRAWL_API_KEY=
